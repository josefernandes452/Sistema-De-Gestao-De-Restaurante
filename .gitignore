# Configuração local (ligação à BD, chaves, etc.)
/config/config.php
.env

# Uploads de utilizadores (manter a pasta, ignorar o conteúdo)
/assets/uploads/*
!/assets/uploads/.gitkeep
!/assets/uploads/.htaccess

# Dependências
/vendor/

# Cache de resultados do PHPUnit (gerado automaticamente ao correr os testes)
.phpunit.result.cache

# Ficheiros de sistema/editor
.DS_Store
Thumbs.db
.claude/
composer.phar

# Cache da API de cambio (gerado automaticamente)
/assets/cache/*.json
/assets/cache/*.log

# Certificados digitais (mTLS da area administrativa). O .pfx tem a
# chave privada do certificado, mesmo com senha nao deve ir para o
# Git. O ca.crt e so a chave publica da CA, esse pode ficar.
/certificados/*.pfx
/certificados/*.key
